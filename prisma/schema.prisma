generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id        Int      @id @default(1)
  name      String   @default("我的彩券行")
  hours     Json     @default("{\"0\":{\"open\":\"08:00\",\"close\":\"22:00\"},\"1\":{\"open\":\"08:00\",\"close\":\"22:00\"},\"2\":{\"open\":\"08:00\",\"close\":\"22:00\"},\"3\":{\"open\":\"08:00\",\"close\":\"22:00\"},\"4\":{\"open\":\"08:00\",\"close\":\"22:00\"},\"5\":{\"open\":\"08:00\",\"close\":\"22:00\"},\"6\":{\"open\":\"08:00\",\"close\":\"22:00\"}}")
  updatedAt DateTime @updatedAt
}

model Employee {
  id        Int        @id @default(autoincrement())
  name      String
  color     String
  active    Boolean    @default(true)
  schedules Schedule[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Schedule {
  id         Int       @id @default(autoincrement())
  weekStart  DateTime
  dayOfWeek  Int
  hour       Int
  rowIndex   Int       @default(0)
  employeeId Int?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([weekStart, dayOfWeek, hour, rowIndex])
}

model ScratchTicket {
  id              Int                   @id @default(autoincrement())
  name            String
  price           Int
  sheetsPerBook   Int
  note            String?
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  inventoryLogs   ScratchInventoryLog[]
  floorInventory  FloorInventory[]
}

model FloorInventory {
  id              Int           @id @default(autoincrement())
  date            DateTime      @db.Date
  scratchTicketId Int
  scratchTicket   ScratchTicket @relation(fields: [scratchTicketId], references: [id])
  unopened        Int           @default(0)
  opened          Int           @default(0)
  onDisplay       Int           @default(0)
  restockSheets   Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([date, scratchTicketId])
}

model DailySummary {
  id                Int      @id @default(autoincrement())
  date              DateTime @db.Date @unique
  lotterySales      Int      @default(0)
  lotteryRedemption Int      @default(0)
  scratchSales      Int      @default(0)
  scratchSheets     Int      @default(0)
  scratchRedemption Int      @default(0)
  sportsSales       Int      @default(0)
  sportsRedemption  Int      @default(0)
  virtualSports     Int      @default(0)
  cash1000          Int      @default(0)
  cash500           Int      @default(0)
  cash100           Int      @default(0)
  cashCoins         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ExtraItemTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  amount    Int      @default(0)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model DailySummaryItem {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  name      String
  amount    Int
  createdAt DateTime @default(now())
}

model MonthlyItemTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  income    Int      @default(0)
  expense   Int      @default(0)
  note      String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model MonthlyItem {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  name      String
  income    Int      @default(0)
  expense   Int      @default(0)
  note      String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([year, month])
}

model ScratchInventoryLog {
  id              Int           @id @default(autoincrement())
  scratchTicketId Int
  scratchTicket   ScratchTicket @relation(fields: [scratchTicketId], references: [id])
  type            String        // "IN" | "OUT"
  books           Int
  time            DateTime      @default(now())
  note            String?
  createdAt       DateTime      @default(now())
}
